{
  "$schema": "https://opencode.ai/config.json",
  "model": "plaximoodin/Qwen3.5-35B-A3B",
  "small_model": "plaximoodin/Qwen3.5-35B-A3B",
  "autoupdate": true,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 15000
  },
  "permission": {
    "bash": "ask",
    "edit": "ask",
    "write": "ask"
  },
  "provider": {
    "plaximoodin": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "PlaximoOdin",
      "options": {
        "baseURL": "http://192.168.10.2:8080/v1",
        "apiKey": "not-required"
      },
      "models": {
        "Qwen3.5-35B-A3B": {
          "name": "Qwen3.5-35B-A3B"
        }
      }
    }
  },
  "instructions": [
    "CONTRIBUTING.md",
    "CODE_STYLE.md"
  ],
  "snapshot": true,
  "watcher": {
    "ignore": [
      "node_modules/**",
      ".git/**",
      "dist/**",
      "build/**",
      "*.log",
      "__pycache__/**",
      ".venv/**",
      "venv/**"
